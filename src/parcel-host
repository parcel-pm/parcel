# set up the environment
TOKEN="broadcast"
ALLOWED_FILES=()
if [ ! -d "$PASSWORD_STORE_DIR" ]; then
    parcel_error "Invalid password store directory: $PASSWORD_STORE_DIR" 1
fi

# token-bucket rate limiter for action_decrypt
DECRYPT_BUCKET_TOKENS=""
DECRYPT_BUCKET_LAST=""
DECRYPT_BUCKET_SIZE_DEFAULT=24 # default also set in schema.js
DECRYPT_BUCKET_RATE_DEFAULT=0.006667 # default also set in schema.js
PARCELFILE="$PASSWORD_STORE_DIR/.parcel.json"
CONFIG="{}"
CONFIG_MODIFIED=0

function get_mtime() {
    stat -L -c %Y "$1" 2>/dev/null || stat -L -f %m "$1"
}

# get a millisecond timestamp with MacOS fallback to whole seconds
function get_timestamp_ms() {
    local TS
    TS="$(date +%s%3N 2>/dev/null)"
    if [[ "$TS" =~ ^[0-9]{13}$ ]]; then
        echo "$TS"
    else
        date +%s000
    fi
}

# load the configuration
function load_config() {
    if [ -f "$PARCELFILE" ]; then
        if ! CONFIG="$(cat "$PARCELFILE")"; then
            parcel_error "Failed to read config file: $PARCELFILE" 1
        fi
        CONFIG_MODIFIED="$(get_mtime "$PARCELFILE")"
    else
        CONFIG="{}"
        CONFIG_MODIFIED="$(date +%s)"
    fi
    local REALPASSDIR="$(readlink -f "$PASSWORD_STORE_DIR")"
    if ! CONFIG="$(jq --arg passdir "$PASSWORD_STORE_DIR" --arg realPassdir "$REALPASSDIR" --arg mtime "$CONFIG_MODIFIED" '. + {modified: ($mtime|tonumber)} + {passdir: $passdir} + {realPassdir: $realPassdir} + (if has("rules") then null else {rules:[{pattern:"."}], defaultRules: true} end)' <<< "$CONFIG")"; then
        parcel_error "Failed to parse config file: $PARCELFILE" 1
    fi
}

# ensure that the config is up to date
function update_config() {
    if [[ ! -f "$PARCELFILE" || -f "$PARCELFILE" && "$CONFIG_MODIFIED" -ne "$(get_mtime "$PARCELFILE")" ]]; then
        load_config
        action_list >/dev/null
    fi
}

# get the current config
function action_configure() {
    update_config
    parcel_send "$CONFIG"
}

# check whether there have been any changes to the password store since the last time the list was generated
function action_changes_since() {
    update_config
    local SINCE="$(jq -r '.since' <<< "$1")"
    if [[ -z "$SINCE" || "$SINCE" == "null" || ! "$SINCE" =~ ^[0-9]{10}$ ]]; then
        parcel_error "Invalid timestamp: $SINCE"
    fi
    SINCE="$(date -d "$SINCE" +'%Y-%m-%d %H:%M:%S' 2>/dev/null || date -j -f "%s" "$SINCE" +'%Y-%m-%d %H:%M:%S')"
    CHANGES=$(find -L "$PASSWORD_STORE_DIR" \( -type d -name '.git' -prune \) -o \( -type d -not -path "$PASSWORD_STORE_DIR/.*" -not -path "$PASSWORD_STORE_DIR/**/.*" -newermt "$SINCE" -print \) | wc -l)
    parcel_send "$(jq -n --arg changes "$CHANGES" '{changes: ($changes|gsub("\\s+"; "")|tonumber)}')"
}

# get a list of all the password entries which match the config
function action_list() {
    update_config
    local MIXED="$(
        {
            find -L "$PASSWORD_STORE_DIR" \( -type d -name '.git' -prune \) -o \( \( -type f -o -type l \) -not -path "$PASSWORD_STORE_DIR/.*" -not -path "$PASSWORD_STORE_DIR/**/.*" -name '*.gpg' -print \)
        } 2>&1 || true
    )"
    local FIND_OUT=""
    local FIND_ERR=""
    while true; do
        IFS= read -r line <<< "" || break
        IFS= read -r line || break
        if [[ "$line" == "find:"* ]]; then
            FIND_ERR+="$line"$'\n'
        else
            FIND_OUT+="$line"$'\n'
        fi
    done <<< "$MIXED"
    if [ -n "$FIND_ERR" ]; then
        parcel_error "Unable to scan files: $FIND_ERR"
        return 0
    fi
    local REAL_OUT="$(printf '%s' "$FIND_OUT" | tr '\n' '\0' | xargs -0 -n100 readlink -f || true)"
    local SYMLINKS=()
    while IFS= read -r link; do
        if [ -n "$link" ]; then
            SYMLINKS+=("$link/")
        fi
    done < <(find "$PASSWORD_STORE_DIR" -not -path "$PASSWORD_STORE_DIR/.*" -not -path "$PASSWORD_STORE_DIR/**/.*" -type l -print)
    local IS_LINK=""
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            local linked=0
            if test -L "$line"; then
                linked=1
            else
                for prefix in "${SYMLINKS[@]}"; do
                    if [[ "$line" == "$prefix"* ]]; then
                        linked=1
                        break
                    fi
                done
            fi
            IS_LINK+="$linked"$'\n'
        fi
    done <<< "$FIND_OUT"
    local OUT="$(
            jq -n --rawfile path <(echo "$FIND_OUT") --rawfile real <(echo "$REAL_OUT") --rawfile is_link <(echo "$IS_LINK") '
                [$path, $real, $is_link]
                | map(rtrimstr("\n") | split("\n") | map(select(length > 0)))
                | transpose
                | map({path: .[0], real: .[1], is_link: (.[2] | tonumber)})
                | {entries: .}
                ' |
            jq -s '
                .[0] * .[1]
                | . as $top
                | ($top.rules|map(select(.ignore==false or (has("ignore") | not)).pattern)) as $include
                | ($top.rules|map(select(.ignore==true).pattern)) as $ignore
                | .entries | (
                    map(
                        .={path: .path, name: .path | ltrimstr($top.passdir + "/") | rtrimstr(".gpg"), is_link: .is_link, real: .real}
                        | . as $entry
                        | select(
                            reduce $include[] as $pattern (false; . or ($entry.name|test($pattern)))
                            and (reduce $ignore[] as $pattern (false; . or ($entry.name|test($pattern)))|not)
                            and (
                                ($entry.is_link == 0)
                                or (
                                    ($top.allowLinks == true) and (
                                        ($entry.real | startswith($top.realPassdir + "/"))
                                        or (($entry.real | startswith($top.realPassdir + "/") | not) and $top.allowExternalLinks == true)
                                    )
                                )
                            )
                        )
                    )
                    | sort_by(.name)

                )
            ' \
                <(echo "$CONFIG") -
    )"

    # kludgery required to set a global array's content using a string of single-quoted strings
    declare -a LOCAL_AF="( $(jq -rc 'map(.path) | @sh' <<< "$OUT") )"
    ALLOWED_FILES=( "${LOCAL_AF[@]}" )

    parcel_send "$OUT"
}

# audit a decryption attempt
function audit_decrypt() {
    local SHOULD_AUDIT="$(jq -r '.auditDecrypt' <<< "$CONFIG")"
    if [ "$SHOULD_AUDIT" != "true" ]; then
        return 0
    fi
    local FILE_PATH="${1//[[:cntrl:]]/}"
    local TIMESTAMP="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    local MESSAGE="${2//[[:cntrl:]]/}"
    local INTENT="${3//[[:cntrl:]]/}"
    local ORIGIN="${4//[[:cntrl:]]/}"
    echo "[$TIMESTAMP] DECRYPT ${INTENT:0:128} ${ORIGIN:0:1024} ${FILE_PATH:0:1024}: ${MESSAGE:0:4096}" >&5
}

# check the token-bucket rate limiter for action_decrypt
function check_decrypt_rate_limit() {
    local BUCKET_SIZE="$(jq -r '.decryptBucket' <<< "$CONFIG")"
    local RATE="$(jq -r '.decryptRate' <<< "$CONFIG")"
    if [ "$BUCKET_SIZE" == "null" ]; then
        BUCKET_SIZE=$DECRYPT_BUCKET_SIZE_DEFAULT
    fi
    if [ "$RATE" == "null" ]; then
        RATE=$DECRYPT_BUCKET_RATE_DEFAULT
    fi
    # rate limiting disabled when bucket or rate is zero
    if [ "$BUCKET_SIZE" -eq 0 ] || awk -v rate="$RATE" 'BEGIN { exit !(rate == 0) }'; then
        return 0
    fi

    local NOW
    NOW="$(get_timestamp_ms)"

    local BUCKET_MILLIS=$((BUCKET_SIZE * 1000))

    if [ -z "$DECRYPT_BUCKET_TOKENS" ] && [ -z "$DECRYPT_BUCKET_LAST" ]; then
        DECRYPT_BUCKET_TOKENS="$BUCKET_MILLIS"
        DECRYPT_BUCKET_LAST="$NOW"
    fi

    local ELAPSED_MS=$((NOW - DECRYPT_BUCKET_LAST))
    local REFILL
    REFILL=$(printf '%s\n' "$ELAPSED_MS $RATE" | awk '{ printf "%.0f", $1 * $2 }')

    DECRYPT_BUCKET_TOKENS=$((DECRYPT_BUCKET_TOKENS + REFILL))
    if [ "$DECRYPT_BUCKET_TOKENS" -gt "$BUCKET_MILLIS" ]; then
        DECRYPT_BUCKET_TOKENS="$BUCKET_MILLIS"
    fi
    DECRYPT_BUCKET_LAST="$NOW"

    if [ "$DECRYPT_BUCKET_TOKENS" -lt 1000 ]; then
        return 1
    fi

    DECRYPT_BUCKET_TOKENS=$((DECRYPT_BUCKET_TOKENS - 1000))
    return 0
}

function path_is_within() {
    local PARENT="$1"
    local CHILD="$2"
    [ "$CHILD" = "$PARENT" ] || [[ "$CHILD" == "$PARENT/"* ]]
}

function path_uses_links() {
    local FILE_PATH="$1"
    local CURRENT="$FILE_PATH"
    while [ "$CURRENT" != "$PASSWORD_STORE_DIR" ] && [ "$CURRENT" != "/" ]; do
        if [ -L "$CURRENT" ]; then
            return 0
        fi
        CURRENT="$(dirname "$CURRENT")"
    done
    [ -L "$PASSWORD_STORE_DIR" ]
}

function validate_decrypt_path_policy() {
    local FILE_PATH="$1"
    if ! path_uses_links "$FILE_PATH"; then
        return 0
    fi
    local ALLOW_LINKS="$(jq -r '.allowLinks' <<< "$CONFIG")"
    if [ "$ALLOW_LINKS" != "true" ]; then
        return 1
    fi
    local REAL_PATH
    if ! REAL_PATH="$(readlink -f "$FILE_PATH" 2>/dev/null)"; then
        return 1
    fi
    local REAL_PASSDIR="$(jq -r '.realPassdir' <<< "$CONFIG")"
    if path_is_within "$REAL_PASSDIR" "$REAL_PATH"; then
        return 0
    fi
    local ALLOW_EXTERNAL_LINKS="$(jq -r '.allowExternalLinks' <<< "$CONFIG")"
    [ "$ALLOW_EXTERNAL_LINKS" = "true" ]
}

# decrypt and return the contents of a password entry
function action_decrypt() {
    update_config
    local FILE_PATH="$(jq -r '.path' <<< "$1")"
    local INTENT="$(jq -r '.intent' <<< "$1")"
    local ORIGIN="$(jq -r '.origin' <<< "$1")"
    if ! check_decrypt_rate_limit; then
        audit_decrypt "$FILE_PATH" "Denied (rate limit)" "$INTENT" "$ORIGIN"
        parcel_error "Decryption rate limit exceeded"
        return 0
    fi
    local ALLOW=0
    local OUT
    for ALLOWED in "${ALLOWED_FILES[@]}"; do
        if [ "$ALLOWED" = "$FILE_PATH" ]; then
            ALLOW=1
            break
        fi
    done
    if [ $ALLOW -ne 1 ]; then
        audit_decrypt "$FILE_PATH" "Denied (path out of scope)" "$INTENT" "$ORIGIN"
        parcel_error "Access Denied: Path out of scope: $FILE_PATH"
        return 0
    fi
    if [ ! -f "$FILE_PATH" ]; then
        audit_decrypt "$FILE_PATH" "File not found" "$INTENT" "$ORIGIN"
        parcel_error "File not found: $FILE_PATH"
        return 0
    fi
    if ! validate_decrypt_path_policy "$FILE_PATH"; then
        audit_decrypt "$FILE_PATH" "Denied (path out of scope)" "$INTENT" "$ORIGIN"
        parcel_error "Access Denied: Path out of scope: $FILE_PATH"
        return 0
    fi
    if ! OUT="$(gpg --decrypt --quiet --batch --no-tty --yes --output - < "$FILE_PATH" 2>/dev/null)"; then
        audit_decrypt "$FILE_PATH" "Decryption failed" "$INTENT" "$ORIGIN"
        parcel_error "Failed to decrypt $FILE_PATH"
        return 0
    fi
    audit_decrypt "$FILE_PATH" "Success" "$INTENT" "$ORIGIN"
    parcel_send "$(jq -n --arg path "$FILE_PATH" --arg plaintext "$OUT" '{path: $path, plaintext: $plaintext}')"
}
