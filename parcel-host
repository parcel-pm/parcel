TOKEN="broadcast"
PARCEL_HOST=""

exec 3>&1
exec 4>&2

# create default startup config file if it doesn't exist
PARCELRC="$HOME/.config/parcel/parcelrc"
if [ ! -e "$PARCELRC" ]; then
    mkdir -p "$(dirname "$PARCELRC")"
    cat > "$PARCELRC" <<EOT
# This file was automatically generated by the parcel-host bootstrap script

# Valid signers for the main host script which is bundled with the extension (space-separated)
#VALID_SIGNERS="88FF14D6294AF4036B7F00FF676A3C09E2E47A72"

# If you use MacOS, you may wish to include homebrew's bin directory in parcel's PATH
#PATH="\$PATH:/opt/homebrew/bin"

# The gpg binary to use.
# Default: gpg
#GPG="gpg"

# The jq binary to use.
# Default: jq
#JQ="jq"

# Where to write the log file
#LOGFILE="\$HOME/.local/log/parcel-host.log"

# The password store directory
#PASSWORD_STORE_DIR="\$HOME/.password-store"
EOT
fi

# load startup config & set up logging for any unexpected stdout or stderr
LOGFILE="$HOME/.local/log/parcel-host.log"
PASSWORD_STORE_DIR="$HOME/.password-store"
. "$PARCELRC"
mkdir -p "$(dirname "$LOGFILE")"
exec 1>>"$LOGFILE"
exec 2>&1
if [ -z "$VALID_SIGNERS" ]; then VALID_SIGNERS="88FF14D6294AF4036B7F00FF676A3C09E2E47A72"; fi
if [ -n "$GPG" ]; then function gpg() { "$GPG" "$@"; return $?; }; fi
if [ -n "$JQ" ]; then function jq() { "$JQ" "$@"; return $?; }; fi

# transmit message in native messaging host protocol
function parcel_transmit() {
    local LC_ALL=C
    local s=$1 n=${#1} b
    printf -v b '\\x%02x\\x%02x\\x%02x\\x%02x' \
        "$(( n       & 255 ))" \
        "$(( n >> 8  & 255 ))" \
        "$(( n >> 16 & 255 ))" \
        "$(( n >> 24 & 255 ))"
    printf '%b%s' "$b" "$s" >&3
}

# sender for errors
# $1: error message
# $2: optional exit code
function parcel_error() {
    if [ ${#1} -gt 0 ]; then
        parcel_transmit "$(jq -n --arg token "$TOKEN" --arg msg "$1" '{token: $token, error: $msg}')"
    fi
    if [ -n "$2" ]; then
        exit $2
    fi
}

# sender for regular messages
# $1: message (JSON object)
function parcel_send() {
    if [ ${#1} -gt 0 ]; then
        parcel_transmit "$(jq --arg token "$TOKEN" '{token: $token, data: .}' <<< "$1")"
    fi
}

# bootstrap host script from extension
function action_install() {
    local SIGNATURE="$(jq -r '.signature' <<< "$1")"
    local SCRIPT="$(jq -r '.script' <<< "$1")"
    if [ "$SIGNATURE" == "null" ] || [ "$SCRIPT" == "null" ]; then
        parcel_error "$(jq -n '{action: "install-result", valid: false, message: "No signature or script was supplied"}')"
        return 0
    fi

    # verify signature
    if ! local OUT="$(gpg --status-fd=1 --quiet --verify --auto-key-import <(echo "$SIGNATURE") <(echo "$SCRIPT") 2>/dev/null)"; then
        parcel_error "Signature verification failed"
        return 0
    fi

    # verify signer
    if ! local SIGNER="$(grep VALIDSIG <<< "$OUT" | cut -d' ' -f12)" || [ -z "$SIGNER" ]; then
        parcel_error "Signature verification failed: No primary fingerprint:\n$OUT"
        return 0
    fi
    if [[ ! " $VALID_SIGNERS " =~ [[:space:]]$SIGNER[[:space:]] ]]; then
        parcel_error "Signature verification failed: Invalid primary fingerprint:\n$OUT"
        return 0
    fi


    PARCEL_HOST="$SCRIPT"

    parcel_send '{"success": true, "message": "Native host script installed successfully"}'
}

# main event loop
function main() {
    while MSG_LEN="$(printf %ld 0x$(dd bs=4 count=1 2> /dev/null | od -An -tx4 | tr -d '[:space:]') 2>/dev/null)"; do
        local MESSAGE="$(head -c $MSG_LEN)"
        local NEW_TOKEN="$(jq -r .token <<< "$MESSAGE")"
        if [ -n "$NEW_TOKEN" ]; then
            TOKEN="$NEW_TOKEN"
        fi
        local ACTION="$(jq -r .action <<< "$MESSAGE")"
        if [ -z "$ACTION" ]; then
            parcel_error "Missing host action"
        else
            if [ "$(type -t "action_$ACTION")" = "function" ]; then
                if ! "action_$ACTION" "$MESSAGE"; then
                    parcel_error "Unknown error for action '$ACTION' - please check the parcel-host log"
                fi
                if [ "$ACTION" = "install" ]; then
                    return 2 # exit the loop after installing the main host script
                fi
            else
                parcel_error "Unknown host action: $ACTION"
            fi
        fi
    done
}

# ensure jq works
if ! command -v jq &> /dev/null; then
    parcel_transmit '{"token: "broadcast", "error":"Cannot find jq ('${JQ:-jq}'): Please configure the correct path for it in parcelrc"}'
    exit 1
fi
if ! jq --version &> /dev/null; then
    parcel_transmit '{"token": "broadcast", "error":"jq is not executable: '"${JQ:-jq}"'"}' 1
    exit 1
fi

# ensure gpg works
if ! command -v gpg &> /dev/null; then
    parcel_error "Cannot find gpg (${GPG:-gpg}): Please configure the correct path for it in parcelrc" 1
fi
if ! gpg --version &> /dev/null; then
    parcel_error "gpg is not executable: ${GPG:-gpg}" 1
fi

# tell the extension that we are ready for bootstrapping
parcel_send '{"action": "bootstrap"}'

# run main event loop
while true; do
    # Load new host script if it exists
    if [ -n "$PARCEL_HOST" ]; then
        eval "$PARCEL_HOST"
        PARCEL_HOST=""
    fi
    # Restart the main loop
    if ! main; then
        if [ $? -eq 2 ]; then
            continue
        fi
    else
        break
    fi
done
